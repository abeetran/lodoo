<odoo>

    <record id="view_esg_environment_tree" model="ir.ui.view">
        <field name="model">esg.environment</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="date"/>
                <field name="electricity_kwh"/>
                <field name="water_m3"/>
                <field name="fuel_liter"/>
                <field name="co2_equivalent"/>
            </tree>
        </field>
    </record>

    <record id="view_esg_environment_form" model="ir.ui.view">
        <field name="model">esg.environment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="date"/>
                    </group>

                    <group string="Consumption">
                        <field name="electricity_kwh"/>
                        <field name="water_m3"/>
                        <field name="fuel_liter"/>
                        <field name="co2_equivalent" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_esg_environment" model="ir.actions.act_window">
        <field name="name">Environment</field>
        <field name="res_model">esg.environment</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>