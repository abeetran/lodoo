<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- NHÓM QUYỀN -->
    <record id="group_knowledge_user" model="res.groups">
        <field name="name">Người dùng Knowledge</field>
        <field name="category_id" ref="base.module_category_productivity"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_knowledge_manager" model="res.groups">
        <field name="name">Quản trị viên Knowledge</field>
        <field name="category_id" ref="base.module_category_productivity"/>
        <field name="implied_ids" eval="[(4, ref('group_knowledge_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <!-- RECORD RULE: User thường -->
    <!-- Logic: xem workspace + (shared nếu là owner HOẶC là member) + (private nếu là owner) -->
    <record id="rule_knowledge_user_access" model="ir.rule">
        <field name="name">Knowledge: Quyền truy cập theo không gian</field>
        <field name="model_id" ref="model_knowledge_article"/>
        <field name="groups" eval="[(4, ref('group_knowledge_user'))]"/>
        <field name="domain_force">['|', '|',
            ('article_type', '=', 'workspace'),
            '&amp;', ('article_type', '=', 'shared'), '|', ('owner_id', '=', user.id), ('article_member_ids.partner_id', '=', user.partner_id.id),
            '&amp;', ('article_type', '=', 'private'), ('owner_id', '=', user.id)
        ]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- RECORD RULE: Manager xem tất cả -->
    <record id="rule_knowledge_manager_all" model="ir.rule">
        <field name="name">Knowledge Manager: Xem tất cả</field>
        <field name="model_id" ref="model_knowledge_article"/>
        <field name="groups" eval="[(4, ref('group_knowledge_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
</odoo>
