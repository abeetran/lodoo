<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- HOME CLIENT ACTION (Dashboard) -->
    <record id="action_knowledge_home" model="ir.actions.client">
        <field name="name">🏠 Trang chủ Knowledge</field>
        <field name="tag">knowledge_home</field>
        <field name="target">main</field>
    </record>

    <!-- RECENT ARTICLES: Action cho bài viết gần đây -->
    <record id="action_knowledge_recent" model="ir.actions.act_window">
        <field name="name">📅 Gần đây</field>
        <field name="res_model">knowledge.article</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_group_type': 0}</field>
        <field name="search_view_id" ref="view_knowledge_article_search"/>
        <field name="domain">[]</field>
    </record>

</odoo>
