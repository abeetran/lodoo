<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- =====================================================================
         TREE VIEW
    ====================================================================== -->
  <record id="view_knowledge_article_tree" model="ir.ui.view">
    <field name="name">knowledge.article.tree</field>
    <field name="model">knowledge.article</field>
    <field name="arch" type="xml">
      <tree string="Bài viết" decoration-muted="not active" multi_edit="1">
        <field name="sequence" widget="handle" />
        <field name="is_favorite" widget="boolean_favorite" nolabel="1" />
        <field name="icon" string="" optional="show" />
        <field name="name" />
        <field name="parent_id" optional="show" />
        <field name="article_type" widget="badge" decoration-info="article_type == 'workspace'" decoration-warning="article_type == 'shared'" decoration-danger="article_type == 'private'" />
        <field name="owner_id" widget="many2one_avatar_user" />
        <field name="last_edition_uid" widget="many2one_avatar_user" optional="show" />
        <field name="last_edition_date" optional="show" />
        <field name="member_count" string="Thành viên" optional="show" />
        <field name="visits" optional="show" />
        <field name="is_locked" widget="boolean" optional="show" />
        <field name="active" column_invisible="True" />
        <button name="action_clone" type="object" string="Nhân bản" icon="fa-copy" title="Nhân bản bài viết" />
      </tree>
    </field>
  </record>

  <!-- =====================================================================
         FORM VIEW
    ====================================================================== -->
  <record id="view_knowledge_article_form" model="ir.ui.view">
    <field name="name">knowledge.article.form</field>
    <field name="model">knowledge.article</field>
    <field name="arch" type="xml">
      <form string="Bài viết" class="o_knowledge_form">

        <header>
          <button name="action_toggle_lock" type="object" string="🔒 Khóa bài viết" invisible="is_locked" class="btn-secondary" />
          <button name="action_toggle_lock" type="object" string="🔓 Mở khóa" invisible="not is_locked" class="btn-warning" />
          <button name="action_clone" type="object" string="📋 Nhân bản" class="btn-secondary" />
          <button name="action_invite_members" type="object" string="👥 Mời thành viên" invisible="article_type == 'workspace'" class="btn-primary" />
          <button name="action_create_child" type="object" string="➕ Bài con" class="btn-secondary" invisible="not id" />
          <button name="action_toggle_template" type="object" string="Lưu làm mẫu" invisible="is_template" class="btn-secondary" />
          <button name="action_toggle_template" type="object" string="Bỏ làm mẫu" invisible="not is_template" class="btn-warning" />
          <button name="action_create_from_template" type="object" string="Tạo bài từ mẫu này" invisible="not is_template" class="btn-primary" />
        </header>

        <sheet class="o_knowledge_sheet">

          <!-- Ảnh bìa (chỉ hiện khi có ảnh) -->
          <div class="o_knowledge_cover" invisible="not cover_image">
            <field name="cover_image" widget="image" options="{'size': [1920, 500], 'zoom': False}" class="o_knowledge_cover_image" nolabel="1" />
          </div>

          <div class="o_knowledge_content_wrapper">

            <!-- TIÊU ĐỀ BLOCK -->
            <div class="o_knowledge_title_block">

              <!-- Icon emoji -->
              <div class="o_knowledge_icon_picker">
                <field name="icon" placeholder="📄" class="o_knowledge_icon_field" nolabel="1" />
              </div>

              <!-- Tiêu đề + Yêu thích -->
              <div class="o_knowledge_title_row">
                <h1 class="o_knowledge_main_title">
                  <field name="name" placeholder="Tiêu đề bài viết..." class="o_knowledge_title_input" nolabel="1" />
                </h1>
                <div class="o_knowledge_title_actions">
                  <field name="is_favorite" widget="boolean_favorite" nolabel="1" class="o_knowledge_favorite_btn" />
                </div>
              </div>

              <!-- Breadcrumb bài cha -->
              <div class="o_knowledge_breadcrumb" invisible="not parent_id">
                <span class="text-muted">
                  <i class="fa fa-folder-open-o me-1" />
                  <field name="parent_id" readonly="1" options="{'no_open': False}" nolabel="1" class="o_knowledge_parent_link" />
                </span>
              </div>

            </div>

            <!-- METADATA BLOCK -->
            <div class="o_knowledge_properties">
              <div class="row g-2 mb-3">

                <div class="col-md-4">
                  <div class="o_form_label o_knowledge_prop_label">
                    <i class=" me-1 text-muted" />Không gian
                  </div>
                  <field name="article_type" widget="badge" decoration-info="article_type == 'workspace'" decoration-warning="article_type == 'shared'" decoration-danger="article_type == 'private'" nolabel="1" />
                </div>

                <div class="col-md-4">
                  <div class="o_form_label o_knowledge_prop_label">
                    <i class="fa fa-user me-1 text-muted" />Chủ sở hữu
                  </div>
                  <field name="owner_id" widget="many2one_avatar_user" nolabel="1" />
                </div>

                <div class="col-md-4">
                  <div class="o_form_label o_knowledge_prop_label">
                    <i class="fa fa-pencil me-1 text-muted" />Chỉnh sửa lần cuối
                  </div>
                  <field name="last_edition_uid" widget="many2one_avatar_user" nolabel="1" />
                  <field name="last_edition_date" nolabel="1" class="text-muted ms-1" readonly="1" />
                </div>

                <div class="col-md-4" invisible="article_type == 'workspace'">
                  <div class="o_form_label o_knowledge_prop_label">
                    <i class="fa fa-users me-1 text-muted" />Thành viên
                  </div>
                  <button name="action_view_members" type="object" class="btn btn-link p-0 o_knowledge_member_btn">
                    <field name="member_count" nolabel="1" />
                    người
                  </button>
                </div>

                <div class="col-md-4">
                  <div class="o_form_label o_knowledge_prop_label">
                    <i class="fa fa-eye me-1 text-muted" />Lượt xem
                  </div>
                  <field name="visits" nolabel="1" readonly="1" />
                </div>

                <div class="col-md-4" invisible="not is_locked">
                  <span class="badge bg-warning text-dark">
                    <i class="fa fa-lock me-1" />Đã khóa
                  </span>
                </div>
                <div class="col-md-4" invisible="not is_template">
                  <div class="o_form_label o_knowledge_prop_label">Loại</div>
                  <span class="badge bg-success text-white">Bài viết mẫu</span>
                </div>
                <div class="col-md-8" invisible="not is_template">
                  <div class="o_form_label o_knowledge_prop_label">Mô tả mẫu</div>
                  <field name="template_description" nolabel="1" placeholder="VD: Dùng cho onboarding nhân viên mới..." />
                </div>
              </div>
            </div>

            <hr class="o_knowledge_divider" />

            <!-- BODY: HTML Editor -->
            <div class="o_knowledge_body_wrapper">
              <field name="body" widget="html" nolabel="1" class="o_knowledge_html_editor" options="{'style-inline': true, 'height': 'auto', 'min_height': 500}" placeholder="Bắt đầu viết nội dung... Gõ '/' để chèn block" readonly="is_locked" />
            </div>

            <!-- FIELD HIDDEN CHO MODIFIERS -->
            <field name="is_locked" invisible="1" />
            <field name="is_template" invisible="1" />

            <!-- BÀI VIẾT CON -->
            <div class="o_knowledge_children" invisible="not child_ids or not id">
              <h4 class="mt-4 mb-3 text-muted">
                <i class="fa fa-sitemap me-2" />Bài viết con
                (
                <field name="child_count" nolabel="1" readonly="1"/>
                )
              </h4>
              <field name="child_ids" nolabel="1">
                <tree create="1" delete="1" editable="bottom" open_form_view="1">
                  <field name="sequence" widget="handle" />
                  <field name="icon" string="" />
                  <field name="name" />
                  <field name="article_type" widget="badge" />
                  <field name="owner_id" widget="many2one_avatar_user" />
                  <field name="last_edition_date" optional="show" />
                </tree>
              </field>
            </div>

          </div><!-- /o_knowledge_content_wrapper -->
        </sheet>

        <!-- CHATTER -->
        <div class="oe_chatter">
          <field name="message_follower_ids" widget="mail_followers" />
          <field name="activity_ids" widget="mail_activity" />
          <field name="message_ids" widget="mail_thread" options="{'post_refresh': 'recipients'}" />
        </div>

      </form>
    </field>
  </record>

  <!-- =====================================================================
         KANBAN VIEW
    ====================================================================== -->
  <record id="view_knowledge_article_kanban" model="ir.ui.view">
    <field name="name">knowledge.article.kanban</field>
    <field name="model">knowledge.article</field>
    <field name="arch" type="xml">
      <kanban class="o_knowledge_kanban" default_group_by="article_type" group_create="false" quick_create="false">
        <field name="id" />
        <field name="name" />
        <field name="icon" />
        <field name="article_type" />
        <field name="owner_id" />
        <field name="is_favorite" />
        <field name="last_edition_date" />
        <field name="last_edition_uid" />
        <field name="is_locked" />
        <field name="visits" />
        <field name="child_count" />
        <templates>
          <t t-name="kanban-box">
            <div class="oe_kanban_card oe_kanban_global_click o_knowledge_kanban_card">
              <div class="o_kanban_card_header d-flex align-items-center">
                <span class="o_knowledge_card_icon me-2" style="font-size:1.5rem;">
                  <t t-esc="record.icon.value || '📄'" />
                </span>
                <strong class="o_kanban_record_title flex-grow-1">
                  <t t-esc="record.name.value" />
                </strong>
                <div class="o_kanban_manage_button_section">
                  <a class="o_kanban_manage_toggle_button" href="#" role="button">
                    <i class="fa fa-ellipsis-v" role="img" aria-label="Manage" />
                  </a>
                </div>
              </div>
              <div class="o_kanban_card_content mt-2">
                <div class="d-flex align-items-center justify-content-between">
                  <field name="owner_id" widget="many2one_avatar_user" />
                  <span class="text-muted small">
                    <i class="fa fa-eye me-1" />
                    <t t-esc="record.visits.value" /> lượt xem
                  </span>
                </div>
                <div class="mt-1 text-muted small">
                  <t t-if="record.child_count.value">
                    <i class="fa fa-sitemap me-1" />
                    <t t-esc="record.child_count.value" /> bài con
                  </t>
                  <t t-if="record.is_locked.value">
                    <i class="fa fa-lock ms-2 text-warning" />
                  </t>
                </div>
              </div>
              <div class="o_kanban_card_footer d-flex align-items-center justify-content-between mt-2">
                <span class="text-muted small">
                  <t t-esc="record.last_edition_date.value" />
                </span>
                <field name="is_favorite" widget="boolean_favorite" nolabel="1" />
              </div>
              <div class="o_kanban_manage_pane dropdown-menu" role="menu">
                <a class="dropdown-item" name="action_clone" type="object">
                  <i class="fa fa-copy me-1" /> Nhân bản
                </a>
                <a class="dropdown-item" name="action_toggle_lock" type="object">
                  <i class="fa fa-lock me-1" /> Khóa / Mở khóa
                </a>
                <div role="separator" class="dropdown-divider" />
                <a class="dropdown-item text-danger" name="action_archive" type="object">
                  <i class="fa fa-archive me-1" /> Lưu trữ
                </a>
              </div>
            </div>
          </t>
        </templates>
      </kanban>
    </field>
  </record>

  <!-- =====================================================================
         SEARCH VIEW
    ====================================================================== -->
  <record id="view_knowledge_article_search" model="ir.ui.view">
    <field name="name">knowledge.article.search</field>
    <field name="model">knowledge.article</field>
    <field name="arch" type="xml">
      <search string="Tìm kiếm bài viết">
        <field name="name" string="Tiêu đề" filter_domain="[('name', 'ilike', self)]" />
        <field name="body" string="Nội dung" filter_domain="[('body', 'ilike', self)]" />
        <field name="owner_id" string="Chủ sở hữu" />
        <field name="parent_id" string="Bài cha" />

        <separator />
        <filter string="⭐ Yêu thích" name="favorites" domain="[('favorite_user_ids', 'in', uid)]" />
        <filter string="👤 Bài của tôi" name="my_articles" domain="[('owner_id', '=', uid)]" />
        <filter string="🔒 Đã khóa" name="locked" domain="[('is_locked', '=', True)]" />
        <separator />
        <filter string="📁 Đã lưu trữ" name="archived" domain="[('active', '=', False)]" />

        <group expand="0" string="Nhóm theo">
          <filter string="Không gian" name="group_type" context="{'group_by': 'article_type'}" />
          <filter string="Chủ sở hữu" name="group_owner" context="{'group_by': 'owner_id'}" />
          <filter string="Bài cha" name="group_parent" context="{'group_by': 'parent_id'}" />
          <filter string="Tháng tạo" name="group_month" context="{'group_by': 'create_date:month'}" />
        </group>

        <searchpanel>
          <field name="article_type" string="KHÔNG GIAN" select="multi" enable_counters="1" />
          <field name="owner_id" string="CHỦ SỞ HỮU" select="multi" enable_counters="1" />
        </searchpanel>
      </search>
    </field>
  </record>

  <!-- =====================================================================
         ACTIONS
    ====================================================================== -->
  <record id="action_knowledge_article_all" model="ir.actions.act_window">
    <field name="name">Tất cả bài viết</field>
    <field name="res_model">knowledge.article</field>
    <field name="view_mode">list,kanban,form</field>
    <field name="search_view_id" ref="view_knowledge_article_search" />
    <field name="context">{}</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">Chưa có bài viết nào!</p>
      <p>Hãy tạo bài viết đầu tiên để bắt đầu xây dựng Knowledge Base.</p>
    </field>
  </record>

  <record id="action_knowledge_article_favorites" model="ir.actions.act_window">
    <field name="name">Bài viết yêu thích</field>
    <field name="res_model">knowledge.article</field>
    <field name="view_mode">list,kanban,form</field>
    <field name="domain">[('favorite_user_ids', 'in', uid)]</field>
    <field name="search_view_id" ref="view_knowledge_article_search" />
  </record>

  <record id="action_knowledge_article_mine" model="ir.actions.act_window">
    <field name="name">Bài viết của tôi</field>
    <field name="res_model">knowledge.article</field>
    <field name="view_mode">list,kanban,form</field>
    <field name="domain">[('owner_id', '=', uid)]</field>
    <field name="search_view_id" ref="view_knowledge_article_search" />
  </record>

  <record id="action_knowledge_workspace" model="ir.actions.act_window">
    <field name="name">Workspace</field>
    <field name="res_model">knowledge.article</field>
    <field name="view_mode">list,kanban,form</field>
    <field name="domain">[('article_type', '=', 'workspace')]</field>
    <field name="search_view_id" ref="view_knowledge_article_search" />
  </record>

  <record id="action_knowledge_private" model="ir.actions.act_window">
    <field name="name">Bài riêng tư</field>
    <field name="res_model">knowledge.article</field>
    <field name="view_mode">list,kanban,form</field>
    <field name="domain">[('article_type', '=', 'private'), ('owner_id', '=', uid)]</field>
    <field name="search_view_id" ref="view_knowledge_article_search" />
  </record>
  <record id="action_knowledge_templates" model="ir.actions.act_window">
    <field name="name">Thư viện mẫu</field>
    <field name="res_model">knowledge.article</field>
    <field name="view_mode">list,kanban,form</field>
    <field name="domain">[('is_template', '=', True)]</field>
    <field name="search_view_id" ref="view_knowledge_article_search" />
  </record>
</odoo>