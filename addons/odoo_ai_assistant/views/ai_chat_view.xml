<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_ai_chat_form" model="ir.ui.view">
    <field name="name">odoo.ai.chat.form</field>
    <field name="model">odoo.ai.chat</field>
    <field name="arch" type="xml">
      <form string="AI Assistant (Raw Data)">
        <header>
          <button name="action_send" string="Gửi lại AI" type="object" class="oe_highlight"/>
        </header>
        <sheet>
          <group>
            <field name="name"/>
            <field name="user_id"/>
            <field name="question"/>
            <field name="suggested_action_xml_id"/>
            <field name="answer"/>
          </group>
        </sheet>
        <div class="oe_chatter">
            <field name="message_follower_ids" widget="mail_followers"/>
            <field name="message_ids" widget="mail_thread"/>
        </div>
      </form>
    </field>
  </record>

  <record id="action_ai_chat_history" model="ir.actions.act_window">
    <field name="name">AI Chat History</field>
    <field name="res_model">odoo.ai.chat</field>
    <field name="view_mode">tree,form</field>
  </record>

  <record id="action_ai_chat_client" model="ir.actions.client">
      <field name="name">AI Assistant</field>
      <field name="tag">odoo_ai_assistant.AiChatClientAction</field>
      <field name="target">current</field> 
  </record>
  <record id="view_ai_knowledge_tree" model="ir.ui.view">
    <field name="name">odoo.ai.knowledge.tree</field>
    <field name="model">odoo.ai.knowledge</field>
    <field name="arch" type="xml">
      <tree editable="bottom">
        <field name="name"/>
        <field name="keyword"/>
        <field name="content"/>
        <field name="active"/>
      </tree>
    </field>
  </record>

  <record id="action_ai_knowledge" model="ir.actions.act_window">
    <field name="name">Thư viện kiến thức AI</field>
    <field name="res_model">odoo.ai.knowledge</field>
    <field name="view_mode">tree</field>
  </record>

  <menuitem id="menu_ai_knowledge" 
            parent="menu_ai_root" 
            name="Thư viện kiến thức" 
            action="action_ai_knowledge" 
            sequence="20"/>
  <menuitem id="menu_ai_root" name="AI Assistant" sequence="10"/>
  <menuitem id="menu_ai_chat_main" 
            parent="menu_ai_root" 
            name="Chat" 
            action="action_ai_chat_client" 
            sequence="1"/>
</odoo>