<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="mcp_prompt_view_tree" model="ir.ui.view">
        <field name="name">mcp.prompt.tree</field>
        <field name="model">mcp.prompt</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="title"/>
                <field name="is_global"/>
                <field name="user_id"/>
                <field name="role"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="mcp_prompt_view_form" model="ir.ui.view">
        <field name="name">mcp.prompt.form</field>
        <field name="model">mcp.prompt</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon"
                            title="Archived"
                            bg_color="text-bg-danger"
                            attrs="{'invisible': [('active','=',True)]}"/>

                    <group>
                        <group>
                            <field name="name"/>
                            <field name="title"/>
                            <field name="role"/>
                        </group>
                        <group>
                            <field name="is_global"/>
                            <field name="user_id"/>
                            <field name="sequence"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Template">
                            <!-- ✅ FIX HERE -->
                            <field name="message_template"
                                   widget="ace"
                                   options="{'mode': 'text'}"/>
                        </page>

                        <page string="Arguments">
                            <field name="argument_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="description"/>
                                    <field name="required"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <record id="mcp_prompt_view_search" model="ir.ui.view">
        <field name="name">mcp.prompt.search</field>
        <field name="model">mcp.prompt</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="title"/>
                <filter name="global" string="Global" domain="[('is_global','=',True)]"/>
                <filter name="my" string="My Prompts" domain="[('user_id','=',uid)]"/>
                <filter name="active" string="Active" domain="[('active','=',True)]"/>
                <filter name="archived" string="Archived" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <record id="action_mcp_prompt" model="ir.actions.act_window">
        <field name="name">MCP Prompts</field>
        <field name="res_model">mcp.prompt</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>
</odoo>