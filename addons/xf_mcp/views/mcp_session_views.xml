<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- TREE -->
    <record id="mcp_session_view_tree" model="ir.ui.view">
        <field name="name">mcp.session.list</field>
        <field name="model">mcp.session</field>
        <field name="arch" type="xml">
            <tree>

                <field name="session_id"/>
                <field name="user_id"/>
                <field name="protocol_version"/>
                <field name="create_date"/>
                <field name="last_activity"/>
                <field name="active"/>

            </tree>
        </field>
    </record>

    <!-- FORM -->
    <record id="mcp_session_view_form" model="ir.ui.view">
        <field name="name">mcp.session.form</field>
        <field name="model">mcp.session</field>
        <field name="arch" type="xml">

            <form create="0">
                <sheet>

                    <group>
                        <group>
                            <field name="session_id"/>
                            <field name="user_id"/>
                            <field name="protocol_version"/>
                        </group>

                        <group>
                            <field name="create_date"/>
                            <field name="last_activity"/>
                            <field name="active"/>
                        </group>
                    </group>

                    <group string="Client Info">
                        <field name="client_info" nolabel="1" colspan="2"/>
                    </group>

                </sheet>
            </form>

        </field>
    </record>

    <!-- SEARCH -->
    <record id="mcp_session_view_search" model="ir.ui.view">
        <field name="name">mcp.session.search</field>
        <field name="model">mcp.session</field>
        <field name="arch" type="xml">

            <search>
                <field name="user_id"/>
                <field name="session_id"/>

                <filter name="active" string="Active"
                        domain="[('active', '=', True)]"/>

                <filter name="terminated" string="Terminated"
                        domain="[('active', '=', False)]"/>

                <group>
                    <filter name="group_user" string="User"
                            context="{'group_by': 'user_id'}"/>
                </group>

            </search>

        </field>
    </record>

    <!-- ACTION FIXED -->
    <record id="action_mcp_session" model="ir.actions.act_window">
        <field name="name">Sessions</field>
        <field name="res_model">mcp.session</field>

        <field name="view_mode">tree,form</field>

        <field name="search_view_id" ref="mcp_session_view_search"/>
        <field name="context">{'search_default_active': 1}</field>
    </record>

</odoo>